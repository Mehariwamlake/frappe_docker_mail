FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    pkg-config \
    build-essential \
    python3-dev \
    libffi-dev \
    libssl-dev \
    libmariadb-dev \
    libjpeg-dev \
    libpng-dev \
    git \
    curl \
    redis-server \
    && rm -rf /var/lib/apt/lists/*
RUN pip install "flit-core<4.0"

RUN pip install frappe-bench

# 👉 CREATE USER (FIX FOR YOUR ERROR)
RUN useradd -ms /bin/bash frappe && \
    mkdir -p /home/frappe && \
    chown -R frappe:frappe /home/frappe

USER frappe
WORKDIR /home/frappe

COPY images/layered/.tmp/apps.json /opt/frappe/apps.json

RUN set -eux && \
  bench init \
    --apps_path=/opt/frappe/apps.json \
    --frappe-branch=version-16 \
    --frappe-path=https://github.com/frappe/frappe \
    --no-backups \
    --verbose \
    /home/frappe/frappe-bench